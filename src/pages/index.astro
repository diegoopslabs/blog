---
import Layout from '../layouts/Layout.astro';
import { getPublishedPosts, getDeskItems } from '../lib/notion';

const start = new Date('2015-01-01').getTime();
const days = Math.floor((Date.now() - start) / 86400000).toLocaleString('en-US');

const allPosts = await getPublishedPosts();
const featured = allPosts[0];
const rest = allPosts.slice(1, 5);

const deskItems = await getDeskItems();

const tabs = [
  { id: 'reading', label: 'Reading', kicker: 'books', panelTitle: 'On the nightstand', panelNote: 'what i read before going to sleep' },
  { id: 'learning', label: 'Learning', kicker: 'courses', panelTitle: 'Currently learning', panelNote: 'sharpening the toolset' },
  { id: 'signals', label: 'Signals', kicker: 'feeds', panelTitle: 'In the feed', panelNote: 'where i keep an ear to the ground' },
  { id: 'building', label: 'Building', kicker: 'projects', panelTitle: 'In the workshop', panelNote: 'side projects that keep me honest' },
];
---

<Layout title="Random Engineer Notes">
	<section class="masthead">
		<div class="oncall-badge">Working&#8209;<br />Since&nbsp;'09</div>

		<p class="whoami">$ whoami &nbsp;&rarr;&nbsp; <span>Platform Engineer · 16 years Learning and Building multi environment solutions</span></p>

		<h1 class="title">Random Engineer<br /><span class="italic">Notes</span><span class="underline"></span></h1>

		<p class="subhead">I have spent sixteen years building, learning, building cloud native stuff, and trying to keep production systems quiet and learn how to break and fix stuff at the same time. These are my notes on the unglamorous craft of reliability &mdash; infrastructure and renamed DevOps and Platform Engineering context, the systems we lean on, and the things I&rsquo;ve actually have fun with, among them, taking advantage of my past experience reacting and solving problems at 3 am (Not On Call anymore).</p>

		<div class="status-strip">
			<span class="status-pill status-pill--dark"><span class="dot dot-green-glow"></span>all Learning on the right track</span>
		</div>
	</section>

	<div class="main-grid">
		<main id="notes">
			<div class="section-head">
				<h2>The Notes</h2>
				<span class="section-head-meta">tail -f /var/log/thoughts</span>
			</div>

			{featured && (
				<a href={`/notes/${featured.slug}`} class="featured-card">
					<div class="featured-top">
						<span class="featured-tag">LATEST</span>
						<span class="featured-meta">{featured.date}</span>
					</div>
					<h3 class="featured-title">{featured.title}</h3>
					<p class="featured-dek">{featured.dek}</p>
					<div class="featured-bottom">
						<span class="featured-tagline">{featured.tags.join('  ·  ')}</span>
						<span class="featured-cta">read note &rarr;</span>
					</div>
				</a>
			)}

			<div class="notes-list">
				{rest.map((n, i) => (
					<a href={`/notes/${n.slug}`} class="note-row">
						<span class="note-num">{String(i + 2).padStart(2, '0')}</span>
						<span class="note-body">
							<span class="note-title">{n.title}</span>
							<span class="note-dek">{n.dek}</span>
							<span class="note-meta">{n.date} &nbsp;·&nbsp; {n.tags.join('  ·  ')}</span>
						</span>
						<span class="note-arrow">&rarr;</span>
					</a>
				))}
			</div>

			{allPosts.length > rest.length + 1 && (
				<div class="load-more-wrap">
					<a href="/notes" class="load-more">load more entries &nbsp;&darr;</a>
				</div>
			)}
		</main>

		<aside id="desk" class="desk">
			<div class="section-head section-head--tight">
				<h2>The Desk</h2>
				<span class="section-head-meta">what's on it</span>
			</div>

			<div class="tabs" role="tablist">
				{tabs.map((tab, i) => (
					<button
						type="button"
						class={`tab-btn${i === 0 ? ' active' : ''}`}
						data-tab={tab.id}
						role="tab"
						aria-selected={i === 0 ? 'true' : 'false'}
					>
						<span class="tab-label">{tab.label}</span>
						<span class="tab-kicker">{tab.kicker}</span>
					</button>
				))}
			</div>

			{tabs.map((tab, i) => {
				const items = deskItems.filter((item) => item.category === tab.label);
				return (
					<div class={`desk-panel${i === 0 ? ' active' : ''}`} data-panel={tab.id} role="tabpanel">
						<h3 class="panel-title">{tab.panelTitle}</h3>
						<p class="panel-note">{tab.panelNote}</p>
						<div class="panel-items">
							{items.map((it) => (
								<div class="panel-item">
									<div class="item-name">{it.name}</div>
									<div class="item-by">{it.by}</div>
									<div class="item-meta">{it.meta}</div>
								</div>
							))}
						</div>
					</div>
				);
			})}

			<p class="desk-footnote"># updated weekly, mostly on sundays<br /># pinned by hand, like a real corkboard</p>
		</aside>
	</div>

	<section id="about" class="about">
		<div>
			<div class="section-head section-head--solo"><h2>About the keeper</h2></div>
			<p class="about-text">I am just a regular random engineer. I have spent sixteen years learning by doing, from customer support, web Development, Cloud Infrastructure, CI/CD, SRE/DevOps stuff (despite I believe job definitions should go beyond labels, and match what you do and what you enjoy doing day to day), and currently I am working as a Platform Engineer. I write here to think out loud about how we keep complex systems boring, humane, and awake-friendly. If something here captures your interest, it did its job.</p>
			<div class="tag-row">
				<span class="tag">kubernetes</span>
				<span class="tag">terraform</span>
				<span class="tag">observability</span>
				<span class="tag">linux</span>
				<span class="tag">incident response</span>
				<span class="tag">Software Development</span>
			</div>
		</div>
		<!--div class="subscribe-card">
			<p class="subscribe-prompt">$ subscribe --inbox</p>
			<p class="subscribe-desc">New notes land roughly every other week. No spam, no funnels just the writing.</p>
			<div class="subscribe-row">
				<input placeholder="you@domain.dev" class="subscribe-input" />
				<button class="subscribe-btn" type="button">join</button>
			</div>
		</div-->
	</section>
</Layout>

<script>
	const tabButtons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
	const panels = document.querySelectorAll<HTMLDivElement>('.desk-panel');

	tabButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const target = btn.dataset.tab;
			tabButtons.forEach((b) => {
				b.classList.toggle('active', b === btn);
				b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
			});
			panels.forEach((p) => p.classList.toggle('active', p.dataset.panel === target));
		});
	});
</script>
