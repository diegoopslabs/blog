---
import Layout from '../../layouts/Layout.astro';
import { getPublishedPosts } from '../../lib/notion';

const posts = await getPublishedPosts();
---

<Layout title="All notes · Random Engineer Notes">
	<main class="archive">
		<a href="/#notes" class="back-link">&larr; home</a>

		<div class="section-head">
			<h2>All Notes</h2>
			<span class="section-head-meta">tail -f /var/log/thoughts</span>
		</div>

		<div class="notes-list">
			{posts.map((n, i) => (
				<a href={`/notes/${n.slug}`} class="note-row">
					<span class="note-num">{String(i + 1).padStart(2, '0')}</span>
					<span class="note-body">
						<span class="note-title">{n.title}</span>
						<span class="note-dek">{n.dek}</span>
						<span class="note-meta">{n.date} &nbsp;·&nbsp; {n.tags.join('  ·  ')}</span>
					</span>
					<span class="note-arrow">&rarr;</span>
				</a>
			))}
		</div>
	</main>
</Layout>

<style>
	.archive { max-width: 760px; margin: 0 auto; padding: 54px 0 70px; }
	.back-link {
		display: inline-block; margin-bottom: 30px; font-family: 'Space Mono', monospace; font-size: 12.5px;
		letter-spacing: .03em; color: var(--muted); text-decoration: none;
	}
	.back-link:hover { color: var(--accent, #bf5a36); }
</style>
